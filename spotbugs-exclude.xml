<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter.

  EI_EXPOSE_REP / EI_EXPOSE_REP2
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  These warnings fire on every Java record and simple DTO that stores or
  returns a mutable collection.  All such objects are intentionally
  lightweight data carriers; callers own their lifecycles.

  CT_CONSTRUCTOR_THROW
  ~~~~~~~~~~~~~~~~~~~~
  SpotBugs flags constructors that throw an exception because a partially-
  constructed object could theoretically be visible via a finalizer attack.
  The three affected classes (CompositePlanValidator, DefaultLivenessDetector,
  RetryMiddleware) do not override finalize(), are not subclassed in a
  security-sensitive context, and the guard is a standard fail-fast precondition
  check.  The warning is suppressed for these three classes only.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
        https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- Value-object mutable-representation warnings -->
  <Match>
    <Bug code="EI,EI2"/>
  </Match>

  <!-- Constructor precondition guards that intentionally throw -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    <Or>
      <Class name="com.agentframework.core.CompositePlanValidator"/>
      <Class name="com.agentframework.core.DefaultLivenessDetector"/>
      <Class name="com.agentframework.action.middleware.RetryMiddleware"/>
    </Or>
  </Match>

</FindBugsFilter>
