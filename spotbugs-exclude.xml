<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclusion filter.

  EI_EXPOSE_REP / EI_EXPOSE_REP2
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  These warnings fire on every Java record and simple DTO that stores or
  returns a mutable collection (List, Map, Set, byte[]).  For value-object
  records generated by the Java compiler the accessor IS the field — there
  is no way to return a defensive copy without either breaking the record
  contract or wrapping every field in an unmodifiable view at construction
  time.  All such objects in this codebase are intentionally lightweight
  data carriers; callers own their lifecycles.  The warning is suppressed
  project-wide for these two codes.

  Real encapsulation bugs (e.g. returning a live internal collection from a
  stateful service class) must be fixed in code, not suppressed here.
-->
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
        https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

  <!-- ── Value-object mutable-representation warnings ───────────────── -->
  <Match>
    <Bug code="EI,EI2"/>
  </Match>

</FindBugsFilter>
